run = "python main.py"
entrypoint = "main.py"
modules = ["python-3.11"]

[env]
PYTHONUNBUFFERED = "1"

[[ports]]
localPort = 5000
externalPort = 80

# reserved_vm: a single always-on, persistent instance. This app keeps per-session
# credentials, captured calls, and the admin feed as in-memory + local-JSON state in
# ONE process, and serves a long-lived SSE stream (/admin/stream). Autoscale would run
# multiple stateless instances and scale to zero, splitting that state across instances
# (SignalWire's cookie-less callbacks could hit an instance that never saw the session)
# and dropping SSE. reserved_vm matches the app's single-process, stateful design.
[deployment]
deploymentTarget = "reserved_vm"
run = ["python", "main.py"]
build = ["sh", "-c", "pip install ."]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[nix]
channel = "stable-25_05"
