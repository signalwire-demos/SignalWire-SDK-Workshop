run = "python main.py"
entrypoint = "main.py"
modules = ["python-3.11"]

[env]
PYTHONUNBUFFERED = "1"
SWML_PROXY_URL_BASE = "https://chicago-roadshow-2026.replit.app"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python", "main.py"]
build = ["sh", "-c", "pip install signalwire-agents signalwire requests fastapi uvicorn"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[nix]
channel = "stable-25_05"
